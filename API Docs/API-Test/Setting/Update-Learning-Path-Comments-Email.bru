meta {
  name: Update Learning Path Comments Email
  type: http
  seq: 15
}

put {
  url: http://localhost:5000/api/v1/settings/email_notify_learning_path_comments
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "key": "email_notify_learning_path_comments",
    "value": "true"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
