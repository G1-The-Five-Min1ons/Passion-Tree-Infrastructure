meta {
  name: Create Platform Announcement (Debug)
  type: http
  seq: 21
}

post {
  url: http://localhost:5000/api/v1/debug/notifications/announcements
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "title": "Platform Updates · Passion-Tree",
    "content": "🚀 New update is live! We improved dashboard speed, fixed login edge-cases, and added better recommendation quality.",
    "is_active": true,
    "publish_at": "2026-03-11T10:00:00Z"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
