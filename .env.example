# Copy this file to .env and fill values

# Service Ports
BACKEND_PORT=8080
AI_PORT=8000
REDIS_PORT=6379
AZURESQL_PORT=1433

# Service URLs (internal Docker network)
AI_SERVICE_URL=http://ai-fastapi:8000
REDIS_URL=redis://redis:6379

# Azure SQL Connection
MSSQL_SA_PASSWORD=YourStrongPassword!123
MSSQL_DB=project_db
AZURESQL_HOST=azuresql
AZURESQL_CONNECTION_STRING=Server=azuresql,1433;Database=project_db;User Id=sa;Password=YourStrongPassword!123;Encrypt=false

# Groq API key for AI service (⚠️ REQUIRED: Get your key from https://console.groq.com)
GROQ_API_KEY=changeme-groq-key
