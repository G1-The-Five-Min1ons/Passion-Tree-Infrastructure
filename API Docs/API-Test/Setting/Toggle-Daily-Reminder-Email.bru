meta {
  name: Toggle Daily Reminder Email
  type: http
  seq: 11
}

put {
  url: http://localhost:5000/api/v1/settings/email_notify_daily_reminder
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "key": "email_notify_daily_reminder",
    "value": "false"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
